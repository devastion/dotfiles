#!/usr/bin/env bash

[[ -z "$BASHRC_LOADED" ]] || return
export BASHRC_LOADED=1

for file in $HOME/.config/shell/*.sh; do
  source "$file"
done

if [[ -z "$LANG" ]]; then
  eval "$(locale)"
fi

export EDITOR="nvim"
export VISUAL="$EDITOR"
export PAGER="less"

path_add() {
  [[ ":$PATH:" != *":$1:"* ]] && PATH="$1:$PATH"
}

path_add "$HOME/.local/bin"

if builtin command -v mise >/dev/null 2>&1; then
  eval "$(mise activate bash)"
fi
