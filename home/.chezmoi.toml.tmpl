{{ $passphrase := promptStringOnce . "passphrase" "passphrase" -}}

sourceDir = "~/projects/github/dotfiles"
encryption = "gpg"
[data]
    passphrase = {{ $passphrase | quote }}
[gpg]
    symmetric = true
    args = ["--batch", "--passphrase", {{ $passphrase | quote }}, "--no-symkey-cache", "--quiet"]
[diff]
    pager = "delta"
