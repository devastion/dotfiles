[core]
  pager = "delta"

[pager]
  diff = delta
  log = delta
  reflog = delta

[interactive]
  diffFilter = "delta --color-only --features=interactive"

[delta]
  features = "decorations"
  line-numbers = true
  hyperlinks = true
  side-by-side = true

[include]
  path = "~/.config/git/tokyonight_night.gitconfig"
; vim:ft=gitconfig
