[init]
  defaultBranch = "main"
  templateDir = "~/.config/git/template"
  commitTemplate = "~/.config/git/commit.template"

[core]
  editor = "nvim"
  excludesFile = "~/.config/git/ignore"
  attributesFile = "~/.config/git/attributes"

[diff]
  tool = "nvimdiff"
  submodule = "log"
  algorithm = "histogram"
  colorMoved = "default"
  colorMovedWS = "allow-indentation-change"
  renames = "copies"
  mnemonicPrefix = true
  indentHeuristic = true

[difftool]
  prompt = false

[difftool "nvimdiff"]
  cmd = "nvim -d \"$LOCAL\" \"$REMOTE\""

[merge]
  renormalize = true
  tool = "nvimdiff"
  conflictstyle = "zdiff3"
  autoStash = true

[mergetool]
  prompt = true
  keepBackup = false

[mergetool "nvimdiff"]
  cmd = "nvim -d \"$LOCAL\" \"$REMOTE\" \"$MERGED\" -c 'wincmd w' -c 'wincmd J'"
  layout = "LOCAL,BASE,REMOTE / MERGED"

[pull]
  ff = "only"

[transfer]
  fsckObjects = true

[fetch]
  prune = true
  pruneTags = true
  parallel = 0
  fsckObjects = true
  writeCommitGraph = true

[receive]
  fsckObjects = true

[commit]
  verbose = true

[tag]
  sort = "version:refname"

[column]
  ui = "auto"

[status]
  showStash = true
  submoduleSummary = true

[stash]
  showPatch = true

[log]
  decorate = "short"
  date = "iso"

[push]
  default = "simple"
  autoSetupRemote = true
  followTags = true
  recurseSubmodules = "check"

[rebase]
  autoSquash = true
  autoStash = true
  instructionFormat = "[%an - %ar] %s"
  updateRefs = true
  missingCommitsCheck = "warn"

[rerere]
  enabled = true

[help]
  autoCorrect = "prompt"

[branch]
  autoSetupMerge = true
  autoSetupRebase = "never"
  sort = "-committerdate"

; force ssh
[url "git@github.com:"]
  insteadOf = "https://github.com/"
  insteadOf = "gh:"

[include]
  path = "~/.config/git/aliases"
  path = "~/.config/git/delta.gitconfig"
  path = "~/.config/git/config.local"
; vim:ft=gitconfig
