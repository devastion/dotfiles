#!/usr/bin/env zsh

export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

export EDITOR="nvim"
export VISUAL="$EDITOR"
export PAGER="bat"

export ZSH_COMPLETIONS_DIR="${ZDOTDIR:-$HOME/.config/zsh}/completions"

[[ -d $ZSH_COMPLETIONS_DIR ]] || mkdir -p "$ZSH_COMPLETIONS_DIR"

typeset -U fpath cdpath

fpath+=(
  "$ZSH_COMPLETIONS_DIR"
  "${ZDOTDIR:-$HOME/.config/zsh}/functions"
)

cdpath+=(
  "${XDG_PROJECTS_DIR:-$HOME/Projects}"
)

export ZPLUGINDIR="${XDG_DATA_HOME:-$HOME/.local/share}/zsh/plugins"

eval "$(/opt/homebrew/bin/brew shellenv)"
